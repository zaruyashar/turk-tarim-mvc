@using EntityLayer.Concrete
@model List<Address>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Adres Bilgileri</h4>
            <div class="table-responsive">
                @if (Model != null && Model.Any())
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Açık Adres</th>
                                <th>Şehir/Ülke</th>
                                <th>E-posta Adresi</th>
                                <th>Telefon Numarası</th>
                                <th>Güncelle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Description1</td>
                                    <td>@item.Description2</td>
                                    <td>@item.Description3</td>
                                    <td>@item.Description4</td>
                                    <td><a asp-controller="Address" asp-action="EditAddress" asp-route-id="@item.AddressID" class="btn btn-outline-success">Güncelle</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state text-center py-5" style="border: 2px dashed #ced4da; border-radius: 12px; background-color: #f8f9fa; margin-top: 20px; margin-bottom: 20px;">
                        <i class="mdi mdi-map-marker-outline" style="font-size: 64px; color: #adb5bd;"></i>
                        <h4 class="mt-3" style="color: #495057; font-weight: 600;">Adres Bilgisi Bulunmuyor</h4>
                        <p style="color: #6c757d; font-size: 15px; margin-bottom: 25px;">Sistemde kayıtlı herhangi bir iletişim veya adres bilgisi bulunmamaktadır. Ziyaretçilerinizin size ulaşabilmesi için adres bilgilerinizi hemen ekleyebilirsiniz.</p>
                        <a asp-controller="Address" asp-action="AddAddress" class="btn btn-info btn-lg">
                            <i class="mdi mdi-plus-circle me-1"></i> Adres Ekle
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (TempData["ProtectedData"] != null)
{
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        Swal.fire({
        title: 'Erişim Engellendi!',
        text: '@Html.Raw(TempData["ProtectedData"])',
        icon: 'info',
        confirmButtonText: 'Anladım',
        confirmButtonColor: '#3085d6'
        });
    </script>
}