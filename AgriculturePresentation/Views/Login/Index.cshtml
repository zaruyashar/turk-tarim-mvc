@model AgriculturePresentation.Models.LogInViewModel

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <title>ADMİN GİRİŞ FORMU</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="~/images/sprout.png?v=2" />
    <link rel="stylesheet" href="~/snow-login-form-starter/css/style.css" type="text/css" media="all" />
    <style>
        .w3l-login {
                height: auto !important;
                background-size: cover !important;
                background-attachment: fixed !important;
                background-position: center !important;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
                justify-content: center;
        }

            .theme-button {
                opacity: 1 !important;
                position: relative;
                z-index: 2;
            }

            #stars, #stars2, #stars3 {
                z-index: 1;
            }

        .brand-logo {
            font-size: 30px !important;
            margin-bottom: 20px !important;
        }

        .new-signup {
            margin-top: 30px;
            text-align: center;
        }

        .signup-text {
            font-size: 15px;
        }

        .sign-link {
            color: #00d2ff !important;
            font-weight: bold;
            text-decoration: underline;
        }

            .sign-link:hover {
                transform: scale(1.1);
                text-decoration: underline;
            }
            
    </style>
</head>

<body>
    <section class="w3l-login">
        <div class="overlay">
            <div class="wrapper">
                <div class="logo">
                    <a class="brand-logo" href="#">TÜRK TARIM</a>
                </div>
                <div class="form-section">
                    <h3>Hoş Geldiniz</h3>
                    <h6>Devam etmek için giriş yapın.</h6>
                    <form method="post" class="signin-form">
                        <div class="form-input">
                            <input type="text" asp-for="UserName" placeholder="Kullanıcı adınız" required="" autofocus>
                        </div>
                        <div class="form-input">
                            <input type="password" asp-for="Password" placeholder="Şifreniz" required="">
                        </div>
                        <button type="submit" class="btn btn-primary theme-button mt-4">Giriş Yap</button>

                        <div class="new-signup">
                            <p class="signup-text">Henüz bir hesabınız yok mu? <a href="/Login/SignUp/" class="sign-link">Kaydolun!</a></p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <div id='stars'></div>
        <div id='stars2'></div>
        <div id='stars3'></div>

        <div class="copy-right">
            <p>&copy; @DateTime.Now.Year. Tüm hakları sakladır. | Geliştiren: <a href="https://github.com/zaruyashar" target="_blank">zaruyashar</a> | Tasarım: <a href="https://w3layouts.com/" target="_blank">W3Layouts</a></p>
        </div>
    </section>


    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @if (TempData["SuccessMessage"]?.ToString() == "PasswordChanged")
    {
        <script>
            Swal.fire({
                title: 'Şifre Değiştirildi!',
                text: 'Güvenliğiniz için lütfen yeni şifrenizle giriş yapın.',
                icon: 'info',
                confirmButtonText: 'Anladım'
            });
        </script>
    }
</body>
</html>
