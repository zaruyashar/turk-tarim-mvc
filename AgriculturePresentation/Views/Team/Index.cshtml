@using EntityLayer.Concrete
@model List<Team>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Ekip Arkadaşlarımız</h4>
            <div class="table-responsive">
                @if (Model != null && Model.Any())
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <td>#</td>
                                <td>ID</td>
                                <td>Ad</td>
                                <td>Görev</td>
                                <td>Sil</td>
                                <td>Düzenle</td>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="py-1 text-center" style="width: 120px;">
                                        @{
                                            var imgUrl = string.IsNullOrWhiteSpace(item.ImageUrl) ? "/images/cute-team-fallback.png" : item.ImageUrl;
                                        }
                                        <div style="display: flex; flex-direction: column; align-items: center; gap: 4px;">
                                            <img src="@imgUrl"
                                                 style="width: 45px; height: 45px; border-radius: 50%; object-fit: cover;"
                                                 onerror="this.onerror=null;this.src='/images/cute-team-fallback.png'; $(this).next('.error-text').show();"
                                                 alt="image" />
        
                                            @if (string.IsNullOrWhiteSpace(item.ImageUrl))
                                            {
                                                <span style="font-size: 10px; color: #fd7e14; font-weight: 700;">Yol Tanımsız</span>
                                            }
                                            else
                                            {
                                                <span class="error-text" style="font-size: 10px; color: #dc3545; font-weight: 700; display:none;">
                                                    Hatalı Yol (404)
                                                </span>
                                            }
                                        </div>
                                    </td>
                                    <td>@item.TeamID</td>
                                    <td>@(string.IsNullOrEmpty(item.PersonName) ? "Belirtilmemiş" : item.PersonName)</td>
                                    <td>@(string.IsNullOrEmpty(item.Title) ? "Belirtilmemiş" : item.Title)</td>
                                    <td>
                                        <form asp-controller="Team" asp-action="DeleteTeam" asp-route-id="@item.TeamID" method="post" style="display:inline;">
                                            <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Bu kaydı silmek istediğinize emin misiniz?');">Sil</button>
                                        </form>
                                    </td>
                                    <td><a asp-controller="Team" asp-action="EditTeam" asp-route-id="@item.TeamID" class="btn btn-outline-success">Güncelle</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <br />
                    <a asp-controller="Team" asp-action="AddTeam" class="btn btn-outline-info">Yeni Personel Girişi</a>
                }
                else
                {
                    <div class="empty-state text-center py-5" style="border: 2px dashed #ced4da; border-radius: 12px; background-color: #f8f9fa; margin-top: 20px; margin-bottom: 20px;">
                        <i class="mdi mdi-account-multiple-outline" style="font-size: 64px; color: #adb5bd;"></i>
                        <h4 class="mt-3" style="color: #495057; font-weight: 600;">Henüz Ekip Arkadaşı Eklenmemiş</h4>
                        <p style="color: #6c757d; font-size: 15px; margin-bottom: 25px;">Sistemde kayıtlı hiçbir personel bulunmuyor. Ziyaretçilerinize ekibinizi tanıtmak için hemen yeni bir kayıt oluşturabilirsiniz.</p>
                        <a asp-controller="Team" asp-action="AddTeam" class="btn btn-info btn-lg">
                            <i class="mdi mdi-plus-circle me-1"></i> İlk Personeli Ekle
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>