@model AgriculturePresentation.Models.TeamAddViewModel

@{
    ViewData["Title"] = "AddTeam";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Yeni Ekip Üyesi Girişi</h4>
            <form class="forms-sample" method="post">
                <div class="form-group">
                    <label for="exampleInputName1">Ad Soyadı</label>
                    <span asp-validation-for="Name" class="text-danger"></span>
                    <input type="text" class="form-control"
                           placeholder="Ad soyadı"
                           asp-for="Name">
                </div>
                <div class="form-group">
                    <label for="exampleInputEmail3">Ünvan</label>
                    <span asp-validation-for="Title" class="text-danger"></span>
                    <input type="text" class="form-control"
                           placeholder="Ünvan"
                           asp-for="Title">
                </div>
                <div class="form-group">
                    <label for="exampleInputEmail3">Görsel Yolu</label>
                    <span asp-validation-for="ImageUrl" class="text-danger"></span>
                    <input type="text" class="form-control"
                           placeholder="Görsel yolu"
                           asp-for="ImageUrl">
                </div>
                <div class="form-group">
                    <label for="exampleInputEmail3">Facebook</label>
                    <input type="text" class="form-control"
                           placeholder="Facebook bağlantısı"
                           asp-for="FacebookUrl">
                </div>
                <div class="form-group">
                    <label for="exampleInputEmail3">Instagram</label>
                    <input type="text" class="form-control"
                           placeholder="Instagram bağlantısı"
                           asp-for="InstagramUrl">
                </div>
                <div class="form-group">
                    <label for="exampleInputEmail3">Twitter</label>
                    <input type="text" class="form-control"
                           placeholder="Twitter bağlantısı"
                           asp-for="TwitterUrl">
                </div>
                <div class="form-group">
                    <label for="exampleInputEmail3">Web Sitesi</label>
                    <input type="text" class="form-control"
                           placeholder="Varsa web sitesi bağlantısı"
                           asp-for="WebsiteUrl">
                </div>
                <button type="submit" class="btn btn-outline-info me-2">Kaydet</button>
                <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
            </form>
        </div>
    </div>
</div>