@using EntityLayer.Concrete
@model List<Announcement>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Duyuru Listesi</h4>
            <div class="table-responsive">
                @if (Model != null && Model.Any())
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Başlık</th>
                                <th>Tarih</th>
                                <th>Durum</th>
                                <th>Durum Değiştir</th>
                                <th>Sil</th>
                                <th>Güncelle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.AnnouncementID</td>
                                    <td>@(string.IsNullOrEmpty(item.Title) ? "Belirtilmemiş" : item.Title)</td>
                                    <td>@item.Date.ToString("dd.MM.yyyy")</td>
                                    <td>@(item.Status ? "Aktif" : "Pasif")</td>
                                    <td>
                                        @if (item.Status)
                                        {
                                            <form asp-controller="Announcement" asp-action="ChangeStatusToFalse" asp-route-id="@item.AnnouncementID" method="post" style="display:inline;">
                                                <button type="submit" class="btn btn-outline-warning">Pasif Yap</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-controller="Announcement" asp-action="ChangeStatusToTrue" asp-route-id="@item.AnnouncementID" method="post" style="display:inline;">
                                                <button type="submit" class="btn btn-outline-info">Aktif Yap</button>
                                            </form>
                                        }
                                    </td>
                                    <td>
                                        <form asp-controller="Announcement" asp-action="DeleteAnnouncement" asp-route-id="@item.AnnouncementID" method="post" style="display:inline;">
                                            <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Bu duyuruyu silmek istediğinize emin misiniz?');">Sil</button>
                                        </form>
                                    </td>
                                    <td><a asp-controller="Announcement" asp-action="EditAnnouncement" asp-route-id="@item.AnnouncementID" class="btn btn-outline-success">Güncelle</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-warning">Sistemde henüz kayıtlı duyuru bulunmamaktadır.</div>
                }
                <br />
                <a asp-controller="Announcement" asp-action="AddAnnouncement" class="btn btn-outline-info">Yeni Duyuru Girişi</a>
            </div>
        </div>
    </div>
</div>