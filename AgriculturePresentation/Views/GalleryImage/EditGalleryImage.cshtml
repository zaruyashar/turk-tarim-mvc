@model EntityLayer.Concrete.GalleryImage

@{
    ViewData["Title"] = "EditGalleryImage";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Görsel Düzenleme Sayfası</h4>
            <form class="forms-sample" method="post">
                <input type="hidden" asp-for="GalleryImageID" />

                <div class="form-group">
                    <label for="exampleInputName1">Başlık</label>
                    <span asp-validation-for="Title" class="text-danger"></span>
                    <input type="text" class="form-control"
                           placeholder="Görsel başlığını girin"
                           asp-for="Title">
                </div>

                <div class="form-group">
                    <label for="exampleInputEmail3">Görsel Yolu</label>
                    <span asp-validation-for="GalleryImageUrl" class="text-danger"></span>
                    <input type="text" class="form-control"
                           placeholder="Görsel yolunu girin"
                           asp-for="GalleryImageUrl">
                </div>

                <div class="form-group">
                <label for="exampleInputEmail3">Açıklama</label>
                <span asp-validation-for="Description" class="text-danger"></span>
                <input type="text" class="form-control"
                       placeholder="Bir açıklama girin"
                       asp-for="Description">
                
                <br />
                <button type="submit" class="btn btn-outline-info me-2">Kaydet</button>
                <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
            </form>
        </div>
    </div>
</div>



