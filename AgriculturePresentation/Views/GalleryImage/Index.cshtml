@using EntityLayer.Concrete
@model List<GalleryImage>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Görsel Listesi</h4>
            <div class="table-responsive">
                @if (Model != null && Model.Any())
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Başlık</th>
                                <th>Sil</th>
                                <th>Güncelle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="py-1">
                                        <img src="@(string.IsNullOrEmpty(item.GalleryImageUrl) ? "/images/default-avatar.png" : item.GalleryImageUrl)" alt="image" />
                                    </td>
                                    <td>@(string.IsNullOrEmpty(item.Title) ? "Belirtilmemiş" : item.Title)</td>
                                    <td>
                                        <form asp-controller="GalleryImage" asp-action="DeleteGalleryImage" asp-route-id="@item.GalleryImageID" method="post" style="display:inline;">
                                            <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Bu görseli silmek istediğinize emin misiniz?');">Sil</button>
                                        </form>
                                    </td>
                                    <td><a asp-controller="GalleryImage" asp-action="EditGalleryImage" asp-route-id="@item.GalleryImageID" class="btn btn-outline-success">Güncelle</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-warning">Sistemde henüz kayıtlı görsel bulunmamaktadır.</div>
                }
                <br />
                <a asp-controller="GalleryImage" asp-action="AddGalleryImage" class="btn btn-outline-info">Yeni Görsel Girişi</a>
            </div>
        </div>
    </div>
</div>