@model AgriculturePresentation.Models.ContactAddViewModel

<div class="col-md-9 contact-middle">
    <h2>Bilgileriniz</h2>
    @using (Html.BeginForm("SendMessage", "Default", FormMethod.Post))
    {
        <div class="form-agileinfo">
            <p>Adınız ve Soyadınız</p>
            <input type="text" asp-for="Name" placeholder="Adınız ve soyadınız" required="" />
            <p>E-posta Adresiniz</p>
            <input type="email" asp-for="Mail" placeholder="E-posta adresiniz" required="" />
        </div>
        <div class="form-agileits-w3layouts">
            <p>Mesajınız</p>
            <textarea asp-for="Message" placeholder="Mesajınız" required=""></textarea>
            <input type="submit" value="MESAJI GÖNDER">
        </div>
        <div class="clearfix"></div>
    }
</div>