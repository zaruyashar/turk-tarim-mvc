@using EntityLayer.Concrete
@model List<Service>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Hizmet Listesi</h4>
            <div class="table-responsive">
                @if (Model != null && Model.Any())
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Başlık</th>
                                <th>Sil</th>
                                <th>Güncelle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="py-1 text-center" style="width: 130px;">
                                        @if (string.IsNullOrWhiteSpace(item.Image) || string.IsNullOrWhiteSpace(item.Class1))
                                        {
                                            <div style="display: flex; flex-direction: column; align-items: center; gap: 4px;">
                                                <i class="fa fa-exclamation-triangle text-danger" style="font-size: 20px;"></i>
                                                <span style="font-size: 10px; color: #dc3545; font-weight: 700; text-transform: uppercase;">
                                                    İkon Eksik!
                                                </span>
                                            </div>
                                        }
                                        else
                                        {
                                            <i class="@item.Image" style="font-size: 24px; color: #4d83ff;"></i>
                                        }
                                    </td>
                                    <td>@(string.IsNullOrEmpty(item.Title) ? "Belirtilmemiş" : item.Title)</td>
                                    <td>
                                        <form asp-controller="Service" asp-action="DeleteService" asp-route-id="@item.ServiceID" method="post" style="display:inline;">
                                            <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Bu hizmeti silmek istediğinize emin misiniz?');">Sil</button>
                                        </form>
                                    </td>
                                    <td><a asp-controller="Service" asp-action="EditService" asp-route-id="@item.ServiceID" class="btn btn-outline-success">Güncelle</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <br />
                    <a asp-controller="Service" asp-action="AddService" class="btn btn-outline-info">Yeni Hizmet Girişi</a>
                }
                else
                {
                    <div class="empty-state text-center py-5" style="border: 2px dashed #ced4da; border-radius: 12px; background-color: #f8f9fa; margin-top: 20px;">
                        <i class="mdi mdi-briefcase-outline" style="font-size: 64px; color: #adb5bd;"></i>
                        <h4 class="mt-3" style="color: #495057; font-weight: 600;">Henüz Hizmet Eklenmemiş</h4>
                        <p style="color: #6c757d; font-size: 15px; margin-bottom: 25px;">Sistemde kayıtlı hiçbir hizmet bulunmuyor. Ziyaretçilerinize sunacağınız hizmetleri hemen eklemeye başlayabilirsiniz.</p>
                        <a asp-controller="Service" asp-action="AddService" class="btn btn-info btn-lg">
                            <i class="mdi mdi-plus-circle me-1"></i> İlk Hizmeti Ekle
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (TempData["ProtectedData"] != null)
{
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        Swal.fire({
        title: 'Erişim Engellendi!',
        text: '@Html.Raw(TempData["ProtectedData"])',
        icon: 'info',
        confirmButtonText: 'Anladım',
        confirmButtonColor: '#3085d6'
        });
    </script>
}