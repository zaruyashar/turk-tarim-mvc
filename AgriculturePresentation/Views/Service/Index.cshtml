@using EntityLayer.Concrete
@model List<Service>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Hizmet Listesi</h4>
            <div class="table-responsive">
                @if (Model != null && Model.Any())
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Başlık</th>
                                <th>Sil</th>
                                <th>Güncelle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="py-1 text-center" style="width: 50px;">
                                        <i class="@item.Image" style="font-size: 24px; color: #4d83ff;"></i>
                                    </td>
                                    <td>@(string.IsNullOrEmpty(item.Title) ? "Belirtilmemiş" : item.Title)</td>
                                    <td><a asp-controller="Service" asp-action="DeleteService" asp-route-id="@item.ServiceID" class="btn btn-outline-danger" onclick="return confirm('Bu hizmeti silmek istediğinize emin misiniz?');">Sil</a></td>
                                    <td><a asp-controller="Service" asp-action="EditService" asp-route-id="@item.ServiceID" class="btn btn-outline-success">Güncelle</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-warning">Sistemde henüz kayıtlı hizmet bulunmamaktadır.</div>
                }
                <br />
                <a asp-controller="Service" asp-action="AddService" class="btn btn-outline-info">Yeni Hizmet Girişi</a>
            </div>
        </div>
    </div>
</div>