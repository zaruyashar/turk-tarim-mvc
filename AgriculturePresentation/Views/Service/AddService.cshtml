@model AgriculturePresentation.Models.ServiceAddViewModel

@{
    ViewData["Title"] = "AddService";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Yeni Hizmet Kaydı</h4>
            <form class="forms-sample" method="post">
                <div class="form-group">
                    <label asp-for="Title">Başlık</label>
                    <input type="text" asp-for="Title" class="form-control" placeholder="Hizmet başlığını giriniz">
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Image">Görsel (İkon Sınıfı)</label>
                    <input type="text" asp-for="Image" class="form-control" placeholder="Örn: fa fa-leaf">
                    <span asp-validation-for="Image" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Description">Açıklama</label>
                    <textarea asp-for="Description" class="form-control" rows="5" placeholder="Hizmet detaylarını yazınız"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-outline-info">Kaydet</button>
                <a href="/Service/Index/" class="btn btn-outline-secondary">İptal</a>
            </form>
        </div>
    </div>
</div>