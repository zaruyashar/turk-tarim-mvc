@using EntityLayer.Concrete
@model List<GalleryImage>

<style>
    .picshade {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        width: 100vw !important;
        height: 100vh !important;
        z-index: 99998 !important;
    }

    .pictures_eyes {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        width: 100vw !important;
        height: 100vh !important;
        z-index: 99999 !important;
        transform: none !important;
        margin: 0 !important;
    }

    .pictures_eyes_in {
        position: absolute !important;
        top: 0 !important;
        left: 0 !important;
        width: 100% !important;
        height: 100% !important;
        display: flex !important;
        justify-content: center !important;
        align-items: center !important;
    }

        .pictures_eyes_in img {
            max-width: 90vw !important;
            max-height: 80vh !important;
            width: auto !important;
            height: auto !important;
            object-fit: contain !important;
            position: static !important;
            margin: 0 !important;
        }

    .pictures_eyes_close {
        position: fixed !important;
        top: 25px !important;
        right: 25px !important;
        z-index: 100000 !important;
    }
</style>

<div class="gallery" id="gallery">
    <div class="container">
        <h3 class="tittle">Fotoğraf Galerisi</h3>
        <p class="heading-btm-w3ls">Organik ürünlerimiz ve bahçelerimizden görseller</p>
        <div class="agile_gallery_grids w3-agile">
            @if (Model != null && Model.Any())
            {
                <ul class="clearfix demo">
                    @foreach (var item in Model)
                    {
                        <li>
                            <div class="gallery-grid1">
                                <img src="@item.GalleryImageUrl" alt="@item.Title" class="img-responsive" style="width:100%; height:250px; object-fit:cover;" />
                                <div class="p-mask">
                                    <h4><span>@(item.Title?.ToUpper(new System.Globalization.CultureInfo("tr-TR")))</span></h4>
                                    <p>@(item.Description?.Length > 60 ? item.Description.Substring(0, 60) + "..." : item.Description)</p>
                                </div>
                            </div>
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="alert alert-warning text-center">
                    Henüz galeriye bir görsel eklenmemiştir.
                </div>
            }
        </div>
    </div>
</div>