@using EntityLayer.Concrete
@model List<Contact>

<div class="row">
    <div class="col-md-12 stretch-card">
        <div class="card">
            <div class="card-body">
                <p class="card-title">Son Mesajlar</p>

                @if (Model != null && Model.Any())
                {
                    <div class="table-responsive">
                        <table id="recent-purchases-listing" class="table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Ad Soyadı</th>
                                    <th>E-posta</th>
                                    <th>Tarih</th>
                                    <th>Mesajı Gör</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.ContactID</td>
                                        <td>
                                            <div style="display: flex; align-items: center; justify-content: space-between; gap: 10px;">
                                                <span style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 150px;">
                                                    @(string.IsNullOrEmpty(item.Name) ? "Belirtilmemiş" : item.Name)
                                                </span>
                                                @if (!item.IsRead)
                                                {
                                                    <span style="background-color: #ff6600 !important; color: #ffffff !important; padding: 3px 8px; border-radius: 4px; font-size: 11px; font-weight: 800; box-shadow: 0 2px 5px rgba(255,102,0,0.4); flex-shrink: 0; display: inline-block; line-height: 1;">YENİ</span>
                                                }
                                            </div>
                                        </td>
                                        <td>@(string.IsNullOrEmpty(item.Mail) ? "Belirtilmemiş" : item.Mail)</td>
                                        <td>@item.Date.ToString("dd.MM.yyyy")</td>
                                        <td>
                                            <a asp-controller="Contact" asp-action="MessageDetails" asp-route-id="@item.ContactID" class="btn btn-primary" style="font-weight: bold !important; color: white !important;">
                                                Mesajı Gör
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-info">
                        Henüz gelen bir mesaj bulunmamaktadır.
                    </div>
                }
            </div>
        </div>
    </div>
</div>