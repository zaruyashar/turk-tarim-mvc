@using EntityLayer.Concrete
@model List<Service>

<style>
    .services-main {
        display: flex !important;
        flex-wrap: wrap !important;
        justify-content: center !important;
        align-items: stretch !important;
    }

        .services-main > div {
            display: flex !important;
            flex-direction: column !important;
            position: relative !important;
            float: none !important;
            margin: 15px !important;
            padding: 2em 1.5em !important;
        }

    @@media (min-width: 992px) {
        .services-main > div {
            width: calc(25% - 30px) !important;
        }
    }

    @@media (min-width: 577px) and (max-width: 991px) {
        .services-main > div {
            width: calc(50% - 30px) !important;
        }
    }

    @@media (max-width: 576px) {
        .services-main > div {
            width: calc(100% - 30px) !important;
        }
    }

    .services-main p {
        height: 85px !important;
        overflow: hidden !important;
        display: -webkit-box !important;
        -webkit-line-clamp: 4 !important;
        -webkit-box-orient: vertical !important;
        margin-bottom: 15px !important;
    }

    .services-main h5 {
        min-height: 40px !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        text-align: center !important;
    }
</style>

<div class="sevices-w3layouts" id="services">
    <div class="container">
        <h3 class="tittle">Hizmetlerimiz</h3>
        <p class="heading-btm-w3ls">Çiftliğimizde sunduğumuz profesyonel tarım çözümleri ve modern üretim teknikleri.</p>

        <div class="services-main">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    bool isBroken = string.IsNullOrWhiteSpace(item.Class1) || string.IsNullOrWhiteSpace(item.Image);

                    if (isBroken)
                    {
                        <div class="sevices-w3layouts-grids" data-wow-delay=".5s">
            
                            <h5 style="color: #f58703; margin-top: 15px;">Kısa Bir Mola...</h5>
                            <p style="color: #ddd; margin-top: 10px; font-size: 14px;">Traktörümüz uykusunu alınca hizmetimiz tekrar yayında olacak!</p>

                            <div class="sevices-w3layouts-img" style="background: url('/images/cute-tractor-fallback.png') center/cover no-repeat;">
                            </div>
            
                        </div>
                    }
                    else
                    {
                        <div class="@item.Class1" data-wow-delay=".5s">
                            <h5>@item.Title</h5>
                            <p>@item.Description</p>

                            <div class="@item.Class2">
                                <i class="@item.Image" aria-hidden="true"></i>
                                <p>@item.Title</p>
                            </div>
                        </div>
                    }
                }
            }
            else
            {
                <div class="alert alert-light text-center">Hizmet bilgileri şu an yüklenemiyor.</div>
            }
        </div>
        <div class="clearfix"> </div>
    </div>
</div>