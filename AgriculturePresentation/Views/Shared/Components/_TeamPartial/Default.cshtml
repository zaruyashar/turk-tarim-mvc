@using EntityLayer.Concrete
@model List<Team>

<style>
    .team-row-custom {
        display: flex !important;
        flex-wrap: wrap !important;
        justify-content: center !important;
        align-items: stretch !important;
    }

        .team-row-custom > div {
            float: none !important;
            margin-bottom: 30px !important;
        }

    .team {
        padding-bottom: 2em !important;
    }

</style>


<div class="team" id="team">
    <div class="container">
        <h3 class="tittle">Ekip Arkadaşlarımız</h3>
        <p class="heading-btm-w3ls">Farklı uzmanlık alanlarına sahip, donanımlı ekip arkadaşlarımız.</p>
        <div class="wthree_team_grids team-row-custom">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <div class="col-md-3 wthree_team_grid">
                        <div class="hovereffect">

                            @{
                                string imagePath = string.IsNullOrWhiteSpace(item.ImageUrl) ? "/images/cute-team-fallback.png" : item.ImageUrl;
                            }

                            <img src="@imagePath" alt="Ekip Üyesi" class="img-responsive" onerror="this.onerror=null;this.src='/images/cute-team-fallback.png';" />
                            
                            <div class="overlay">
                                <div class="rotate">
                                    <p class="group1">
                                        <a href="@(item.TwitterUrl ?? "#")" target="_blank" rel="noopener noreferrer">
                                            <i class="fa fa-twitter"></i>
                                        </a>
                                        <a href="@(item.FacebookUrl ?? "#")" target="_blank" rel="noopener noreferrer">
                                            <i class="fa fa-facebook"></i>
                                        </a>
                                    </p>
                                    <hr>
                                    <hr>
                                    <p class="group2">
                                        <a href="@(item.InstagramUrl ?? "#")" target="_blank" rel="noopener noreferrer">
                                            <i class="fa fa-instagram"></i>
                                        </a>
                                        <a href="@(item.WebsiteUrl ?? "#")" target="_blank" rel="noopener noreferrer">
                                            <i class="fa fa-dribbble"></i>
                                        </a>
                                    </p>
                                </div>
                            </div>
                        </div>
                        <h4>@item.PersonName</h4>
                        <p>@item.Title</p>
                    </div>
                }
            }
            else
            {
                <div class="glass-empty-container">
                    <div class="glass-card">
                        <div class="glass-icon-wrapper">
                            <img src="/images/emptystate-cute-fallback.png" alt="Dinlenen Ekip" />
                        </div>
                        <h4 class="glass-title">Ekibimiz Şimdilik Molada...</h4>
                        <p class="glass-text">
                            Çiftliğimizin kahramanları şu an tarlada çalışıyor veya kısa bir çay molasında. Çok yakında yetenekli ve donanımlı kadromuzla buradayız!
                        </p>
                    </div>
                </div>
            }
            <div class="clearfix"> </div>
        </div>
    </div>
</div>