@using EntityLayer.Concrete
@model List<Contact>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Gelen Mesajlar</h4>
            <div class="table-responsive">
                @if (Model != null && Model.Any())
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Gönderen</th>
                                <th>E-posta</th>
                                <th>Tarih</th>
                                <th>Sil</th>
                                <th>Mesajı Gör</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.ContactID</td>
                                    <td>
                                        <div style="display: flex; align-items: center; justify-content: space-between; gap: 10px;">
                                            <span style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 150px;">
                                                @(string.IsNullOrEmpty(item.Name) ? "Belirtilmemiş" : item.Name)
                                            </span>
                                            @if (!item.IsRead)
                                            {
                                                <span style="background-color: #ff6600 !important; color: #ffffff !important; padding: 3px 8px; border-radius: 4px; font-size: 11px; font-weight: 800; box-shadow: 0 2px 5px rgba(255,102,0,0.4); flex-shrink: 0; display: inline-block; line-height: 1;">YENİ</span>
                                            }
                                        </div>
                                    </td>
                                    <td>@(string.IsNullOrEmpty(item.Mail) ? "Belirtilmemiş" : item.Mail)</td>
                                    <td>@item.Date.ToString("dd.MM.yyyy")</td>
                                    <td>
                                        <a asp-controller="Contact" asp-action="DeleteMessage" asp-route-id="@item.ContactID" class="btn btn-outline-danger" onclick="return confirm('Bu mesajı silmek istediğinize emin misiniz?');">Sil</a>
                                    </td>
                                    <td>
                                        <a asp-controller="Contact" asp-action="MessageDetails" asp-route-id="@item.ContactID" class="btn btn-outline-success">Mesajı Gör</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-warning">Sistemde henüz gelen mesaj bulunmamaktadır.</div>
                }
            </div>
        </div>
    </div>
</div>