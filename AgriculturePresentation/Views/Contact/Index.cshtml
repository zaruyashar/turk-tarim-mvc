@using EntityLayer.Concrete
@model List<Contact>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Gelen Mesajlar</h4>
            <div class="table-responsive">
                @if (Model != null && Model.Any())
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Gönderen</th>
                                <th>E-posta</th>
                                <th>Tarih</th>
                                <th>Sil</th>
                                <th>Mesajı Gör</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.ContactID</td>
                                    <td>@(string.IsNullOrEmpty(item.Name) ? "Belirtilmemiş" : item.Name)</td>
                                    <td>@(string.IsNullOrEmpty(item.Mail) ? "Belirtilmemiş" : item.Mail)</td>
                                    <td>@item.Date.ToString("dd.MM.yyyy")</td>
                                    <td><a href="/Contact/DeleteMessage/@item.ContactID" class="btn btn-outline-danger" onclick="return confirm('Bu mesajı silmek istediğinize emin misiniz?');">Sil</a></td>
                                    <td><a href="/Contact/MessageDetails/@item.ContactID" class="btn btn-outline-success">Mesajı Gör</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-warning">Sistemde henüz gelen mesaj bulunmamaktadır.</div>
                }
            </div>
        </div>
    </div>
</div>