@model EntityLayer.Concrete.Contact

@{
    ViewData["Title"] = "MessageDetails";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Mesaj Detayları</h4>
            
            <form class="forms-sample">
                <div class="form-group">
                    @Html.HiddenFor(x => x.ContactID)

                    <label for="exampleInputName1">Ad Soyadı</label>
                    <input type="text" class="form-control" asp-for="Name" readonly>
                </div>
                <div class="form-group">
                     <label for="exampleInputName1">E-posta Adresi</label>
                     <input type="text" class="form-control" asp-for="Mail" readonly>
                </div>
                <div class="form-group">
                     <label for="exampleInputName1">Tarih</label>
                     <input type="text" class="form-control" asp-for="Date" asp-format="{0:dd.MM.yyyy}" readonly>
                </div>
                <div class="form-group">
                     <label for="exampleInputName1">Mesaj Detayı</label>
                     <textarea class="form-control" cols="5" rows="10" asp-for="Message" readonly></textarea>
                </div>
            </form>
                        
             <div class="d-flex mt-4">
                  <a href="/Contact/Index/" class="btn btn-outline-info me-2">Mesajlara Dön</a>
                
                  <form asp-controller="Contact" asp-action="DeleteMessage" asp-route-id="@Model.ContactID" method="post" onsubmit="return confirm('Bu mesajı güvenli bir şekilde silmek istediğinize emin misiniz?');">
                       <button type="submit" class="btn btn-outline-secondary">Mesajı Sil</button>
                  </form>
             </div>

        </div>
    </div>
</div>