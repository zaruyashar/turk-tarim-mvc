@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Raporlar (Excel)</h4>
            <p class="card-description">
                Sistemdeki verileri dışa aktarmak için ilgili rapor türünü seçebilirsiniz.
            </p>
            
            <div class="mt-4">
                <div class="form-group">
                    <a href="/Report/StaticReport/" class="btn btn-outline-info btn-lg btn-block text-left">
                        <i class="mdi mdi-file-document-outline mr-2" style="font-size: 20px;"></i> Statik Raporlar
                    </a>
                </div>

                <div class="form-group">
                    <a href="/Report/ContactReport/" class="btn btn-outline-info btn-lg btn-block text-left">
                        <i class="mdi mdi-email-outline mr-2" style="font-size: 20px;"></i> Mesaj Raporları
                    </a>
                </div>

                <div class="form-group">
                    <a href="/Report/AnnouncementReport/" class="btn btn-outline-info btn-lg btn-block text-left">
                        <i class="mdi mdi-bullhorn-outline mr-2" style="font-size: 20px;"></i> Duyuru Raporları
                    </a>
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary btn-sm">
                        <i class="mdi mdi-home-outline mr-1"></i> Ana Sayfa
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>